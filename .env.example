# OpenRouter API key (free tier: https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# N8N webhook URL (Part 2)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/campaign-alerts

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Google Sheet ID for warning logs (optional)
GOOGLE_SHEET_ID=your-sheet-id

# Prisma database URL (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Redis URL for BullMQ worker (optional)
REDIS_URL=redis://127.0.0.1:6379

# Monitor interval in minutes for BullMQ worker (default: 5)
MONITOR_INTERVAL_MIN=5
